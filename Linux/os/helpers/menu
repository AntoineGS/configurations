show_theme_menu() {
  theme=$(menu "Theme" "$(theme-list)" "-W 350" "$(theme-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    theme-set "$theme"
  fi
}

show_background_menu() {
  local theme_name bg_list selection
  theme_name=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null)

  bg_list=$(find -L "$HOME/.config/omarchy/backgrounds/$theme_name" "$HOME/.config/omarchy/current/theme/backgrounds" -maxdepth 1 -type f 2>/dev/null | sort -u)

  if [[ -z $bg_list ]]; then
    notify-send "No backgrounds found for current theme" -t 2000
    back_to show_style_menu
    return
  fi

  selection=$(menu "Background" "$bg_list" "-W 800")

  if [[ -z $selection ]]; then
    back_to show_style_menu
    return
  fi

  [[ -n $selection ]] && theme-bg-set "$selection"
}

show_font_menu() {
  theme=$(menu "Font" "$(font-list)" "-W 350" "$(font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    font-set "$theme"
  fi
}

