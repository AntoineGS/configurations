show_style_menu() {
  case $(menu "Style" "¾░Ėī  Theme\nŅÖÖ  Font\n’ĆŠ  Background\n’ŹÖ  Hyprland\n¾▒ää  Screensaver\n") in
  *Theme*) show_theme_menu ;;
