show_system_menu() {
  local options="¾▒ää  Screensaver\n’ĆŻ  Lock"
  [[ ! -f ~/.local/state/omarchy/toggles/suspend-off ]] && options="$options\n¾░Æ▓  Suspend"
  hibernation-available && options="$options\n¾░żü  Hibernate"
  options="$options\n¾░Źā  Logout\n¾░£ē  Restart\n¾░Éź  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) launch-screensaver force ;;
  *Lock*) lock-screen ;;
